<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Courses -->
    <bean id="cour1" class="com.example.Course">
        <property name="courseId" value="1"/>
        <property name="courseName" value="Java"/>
    </bean>

    <bean id="cour2" class="com.example.Course">
        <property name="courseId" value="2"/>
        <property name="courseName" value="Python"/>
    </bean>

    <!-- Students -->
    <bean id="stud1" class="com.example.Student">
        <property name="studId" value="1"/>
        <property name="name" value="John"/>
        <property name="course" ref="cour1"/>
    </bean>

    <bean id="stud2" class="com.example.Student">
        <property name="studId" value="2"/>
        <property name="name" value="Jane"/>
        <property name="course" ref="cour2"/>
    </bean>

</beans>